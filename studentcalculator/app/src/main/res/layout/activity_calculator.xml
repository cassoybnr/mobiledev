<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:textSize="48sp"
        android:text="0"
        android:maxLines="1"
        android:layout_marginBottom="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4">

        <Button android:id="@+id/btn7" android:text="7" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn8" android:text="8" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn9" android:text="9" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnDivide" android:text="/" android:layout_columnWeight="1" />

        <Button android:id="@+id/btn4" android:text="4" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn5" android:text="5" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn6" android:text="6" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnMultiply" android:text="*" android:layout_columnWeight="1" />

        <Button android:id="@+id/btn1" android:text="1" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn2" android:text="2" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn3" android:text="3" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnSubtract" android:text="-" android:layout_columnWeight="1" />

        <Button android:id="@+id/btnClear" android:text="C" android:layout_columnWeight="1" />
        <Button android:id="@+id/btn0" android:text="0" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnEquals" android:text="=" android:layout_columnWeight="1" />
        <Button android:id="@+id/btnAdd" android:text="+" android:layout_columnWeight="1" />

        <Button
            android:id="@+id/btnShowId"
            android:text="Show ID"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal" />

        <Button
            android:id="@+id/btnSquare"
            android:text="x²"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal" />

        <Button
            android:id="@+id/btnTurnOff"
            android:text="Turn Off"
            android:layout_columnSpan="4"
            android:layout_columnWeight="1"
            android:layout_gravity="fill_horizontal"
            android:layout_marginTop="8dp" />

    </GridLayout>
</LinearLayout>
